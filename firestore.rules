// ===========================================
// REGRAS DE SEGURANÇA DO FIRESTORE
// ===========================================
// Copie e cole estas regras no Firebase Console:
// Firestore Database > Regras
// ===========================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regras para transações da família "camargo"
    // Em modo anônimo, todos os usuários anônimos compartilham os mesmos dados
    match /family/{familyId}/transactions/{transactionId} {
      // Permite leitura se o usuário estiver autenticado
      allow read: if request.auth != null;
      
      // Permite escrita (criar) se:
      // 1. Usuário está autenticado
      // 2. Os dados são válidos
      allow create: if request.auth != null 
                    && isValidTransaction(request.resource.data);
      
      // Permite atualização se o usuário está autenticado
      allow update: if request.auth != null 
                    && isValidTransaction(request.resource.data);
      
      // Permite deleção se o usuário está autenticado
      allow delete: if request.auth != null;
    }
    
    // Função para validar estrutura da transação
    function isValidTransaction(data) {
      return data.keys().hasAll(['desc', 'val', 'cat', 'type'])
             && data.desc is string
             && data.desc.size() > 0
             && data.desc.size() <= 200
             && data.val is number
             && data.val > 0
             && data.cat is string
             && data.type in ['in', 'out'];
    }
    
    // Bloqueia acesso a qualquer outro documento
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
